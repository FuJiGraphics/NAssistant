{
  "name": "nassistant",
  "displayName": "NAssistant",
  "description": "AI-neutral context helper for VS Code.",
  "version": "0.2.2",
  "publisher": "fujigraphics",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:nassistant.copyFileReferenceForAi",
    "onCommand:nassistant.copySelectionAsAiContext",
    "onView:nassistant.sidebar"
  ],
  "contributes": {
    "commands": [
      {
        "command": "nassistant.copyFileReferenceForAi",
        "title": "NAssistant: Copy File Reference for AI"
      },
      {
        "command": "nassistant.copySelectionAsAiContext",
        "title": "NAssistant: Copy Selection Location for AI"
      }
    ],
    "keybindings": [
      {
        "command": "nassistant.copySelectionAsAiContext",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "nassistant.copyFileReferenceForAi",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "filesExplorerFocus && resourceSet && !explorerResourceIsFolder"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "nassistant.copySelectionAsAiContext",
          "when": "editorTextFocus && editorHasSelection",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "nassistant.copyFileReferenceForAi",
          "when": "resourceSet && !explorerResourceIsFolder",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nassistant",
          "title": "NAssistant",
          "icon": "media/nassistant.svg"
        }
      ]
    },
    "views": {
      "nassistant": [
        {
          "id": "nassistant.sidebar",
          "name": "NAssistant"
        }
      ]
    }
  },
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "1.90.0",
    "typescript": "^5.4.5"
  }
}
